{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(mkdir -p agent_logs)",
      "Bash(npx vitest run*)",
      "Bash(node qa_test.mjs*)",
      "Bash(npm test:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push:*)"
    ]
  },
  "sandbox": {
    "filesystem": {
      "allowWrite": ["./agent_logs"]
    }
  },
  "env": {
    "PLAYWRIGHT_BROWSERS_PATH": "/tmp/pw-browsers"
  }
}
