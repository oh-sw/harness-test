{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(echo:*)",
      "Bash(mkdir -p agent_logs*)",
      "Bash(echo * >> agent_logs/*)",
      "Bash(printf * >> agent_logs/*)",
      "Bash(npx vitest run*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [],
    "PreToolUse": [],
    "UserPromptSubmit": [],
    "SessionStart": [],
    "Stop": []
  },
  "env": {
    "PLAYWRIGHT_BROWSERS_PATH": "/tmp/pw-browsers"
  }
}
